{
  "name": "satellites-guard",
  "version": "1.0.0",
  "description": "Enforces mandatory Satellites context acquisition before code mutations. Blocks Write/Edit/Bash tool calls until satellites_acquire_context has been called for the current session.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-validate.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/gate-write.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/gate-write.sh"
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/gate-write.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/gate-bash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__.*__satellites_acquire_context",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/mark-acquired.sh"
          }
        ]
      },
      {
        "matcher": "mcp__.*__satellites_reviewer_submit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/mark-closed.sh"
          }
        ]
      }
    ]
  }
}
